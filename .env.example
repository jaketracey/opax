# =============================================================================
# OPAX Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================

# --- Required ---

# Claude API key for RAG answering (parli/rag.py)
ANTHROPIC_API_KEY=sk-ant-...

# --- Data Source APIs ---

# TheyVoteForYou API for voting record data
TVFY_API_KEY=

# OpenAustralia API for Hansard downloads
OPENAUSTRALIA_API_KEY=

# Guardian API for news articles (optional, falls back to 'test' key)
GUARDIAN_API_KEY=

# --- Optional (for future use) ---

# Redis URL (if running with --profile full)
# REDIS_URL=redis://redis:6379/0
